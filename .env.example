# ───────────────────────────────────────────────────────────────
# Notice admin panel configuration
# Set these in Vercel → Project → Settings → Environment Variables.
# Do NOT commit real values (this is just a template).
# ───────────────────────────────────────────────────────────────

# The shared password the school office types at /admin.html to sign in.
# Use something long and not guessable.
ADMIN_PASSWORD=

# A long random string used to sign login session cookies.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=

# BLOB_READ_WRITE_TOKEN is added automatically the moment you create a
# Vercel Blob store (Storage → Create → Blob) and connect it to this project.
# You normally do NOT need to paste it here by hand.
# BLOB_READ_WRITE_TOKEN=
